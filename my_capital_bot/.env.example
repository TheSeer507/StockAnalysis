# Copy this file to .env and fill in your real values.
# .env is gitignored and will never be committed.

CAPITAL_API_KEY=your_capital_api_key_here
CAPITAL_API_SECRET=your_capital_api_secret_here
CAPITAL_LOGIN=your_email@example.com
CAPITAL_PASSWORD=your_password_here
CAPITAL_CUSTOM_PASSWORD=your_custom_password_here
# Set to true for demo account, false for live trading
CAPITAL_IS_DEMO=true
